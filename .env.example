# ==============================================================================
# ENVIRONMENT VARIABLES TEMPLATE
# Rename this file to .env.local and populate the variables before running.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Connections (PostgreSQL via Prisma)
# ------------------------------------------------------------------------------
# DATABASE_URL: Transaction-mode pooler or standard connection string
DATABASE_URL="postgresql://user:password@host:port/database"

# DIRECT_URL: Session-mode connection string used for Prisma migrations
DIRECT_URL="postgresql://user:password@host:port/database"

# ------------------------------------------------------------------------------
# 2. AI SDK (Google Gemini)
# ------------------------------------------------------------------------------
# API Key for Google Generative AI (Gemini 2.5 Flash Grounded)
# Obtain from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY="your_google_gemini_api_key"

# ------------------------------------------------------------------------------
# 3. NextAuth.js Configuration
# ------------------------------------------------------------------------------
# Generated secret for signing JWT sessions.
# Generate via: openssl rand -base64 32
AUTH_SECRET="your_secure_auth_secret_here"

# ------------------------------------------------------------------------------
# 4. Supabase Client Configuration (Optional frontend access)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your_anon_key_here"

# ------------------------------------------------------------------------------
# 5. OAuth Providers (Google)
# ------------------------------------------------------------------------------
# Obtain client credentials from Google Cloud Console: https://console.cloud.google.com/
AUTH_GOOGLE_ID="your_google_client_id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your_google_client_secret"

